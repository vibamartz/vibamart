rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { 
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == "phone"
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email == 'vk311779@gmail.com' && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Validation Blueprints ---
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.uid is string && 
             (data.email is string || data.phone is string) && 
             data.role in ['customer', 'admin', 'vendor'];
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.categoryId is string &&
             data.vendorId is string &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return (isSignedIn() ? data.customerId == request.auth.uid : data.customerId == 'guest') &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    function isValidAdminLog(data) {
      return data.adminId == request.auth.uid &&
             data.adminEmail is string &&
             data.action is string &&
             data.description is string &&
             data.timestamp == request.time;
    }

    function isValidBanner(data) {
      return data.id is string && data.image is string && data.title is string &&
             data.active is bool && data.order is number;
    }

    function isValidCoupon(data) {
      return data.code is string && data.type in ['percent', 'flat'] &&
             data.value is number && data.minAmount is number && data.expiry is string;
    }

    function isValidReview(data) {
      return data.id is string && data.productId is string && data.userId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt is string;
    }

    function isValidAnnouncement(data) {
      return data.id is string && data.title is string && data.content is string &&
             data.type in ['sale', 'info', 'critical'] && data.active is bool;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isVerified() && isValidUser(incoming()) && userId == request.auth.uid;
      allow update: if isVerified() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phone', 'address', 'wishlist', 'addresses', 'cart'])) ||
        isAdmin()
      );
    }

    match /waitlist/{itemId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isVerified() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor');
      allow update: if isVerified() && (
        isAdmin() || (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor' &&
          existing().vendorId == request.auth.uid &&
          incoming().diff(existing()).affectedKeys().hasOnly(['price', 'discountPrice', 'stock', 'description', 'images', 'rating', 'numReviews', 'variants', 'features'])
        )
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if (isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin())) || resource.data.customerId == 'guest';
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if (isVerified() || (incoming().customerId == 'guest' && !isSignedIn())) && isValidOrder(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.customerId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status == 'cancelled' &&
        existing().status == 'pending'
      );
    }

    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidAdminLog(incoming());
     }

    match /notifications/{notifId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
      allow create: if true;
    }

    match /notificationLogs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified() && isValidReview(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Connectivity Test ---
    match /test/connection {
      allow read: if true;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isVerified() && (incoming().userId == request.auth.uid || incoming().customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /cancellation_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isVerified() && (incoming().userId == request.auth.uid || incoming().customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /return_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isVerified() && (incoming().userId == request.auth.uid || incoming().customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /refund_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isVerified() && (incoming().userId == request.auth.uid || incoming().customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
