rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.uid is string && 
             data.email is string && 
             data.role in ['customer', 'admin', 'vendor'] &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.categoryId is string &&
             data.vendorId is string &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.customerId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    // --- Collections ---

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isVerified() && isValidUser(incoming()) && incoming().uid == request.auth.uid;
      allow update: if isVerified() && (
        isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phone', 'address']) ||
        isAdmin()
      );
    }

    // CATEGORIES
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor');
      allow update: if isAdmin() || (
        isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor' &&
        existing().vendorId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['price', 'discountPrice', 'stock', 'description', 'images'])
      );
      allow delete: if isAdmin();
    }

    // ORDERS
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().customerId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidOrder(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && isOwner(existing().customerId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status == 'cancelled' &&
        existing().status == 'pending'
      );
    }

    // SETTINGS
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
